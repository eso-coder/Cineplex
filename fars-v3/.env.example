# FARS v3 — .env namunasi. Bu faylni `.env` deb nusxalab, qiymatlarni to'ldiring.
# (.env git'ga TUSHMAYDI — maxfiy kalitlar har bir kompyuterda qo'lda kiritiladi)

# ── AWS S3 (eski uploader — Bunny'ga o'tilgach ixtiyoriy) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET=

# ── Metadata API kalitlari ──
OMDB_API_KEY=
TMDB_API_KEY=
YOUTUBE_API_KEY=

# ── Admin panel (avtomatlash) ──
ADMIN_URL=https://cineplex.uz/pages/admin.html
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Bunny Stream (yangi video pipeline) ──
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_CDN_HOSTNAME=
