# ── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cineplex

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Email: Resend (birinchi priority) ────────────────
# resend.com dan API key olish: app.resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP — Resend yo'q bo'lsa ishlaydi) ──
# Gmail App Password olish uchun:
#   myaccount.google.com → Security → 2-Step Verification → App passwords
#
# Quyidagi nomlardan istalganini ishlating (barchasi bir xil ishlaydi):
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Yoki SMTP_USER / SMTP_PASS:
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Email "From" nomi (ixtiyoriy):
# MAIL_FROM=CINEPLEX <no-reply@cineplex.app>

# ── Cloudinary (rasm yuklash) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth (ixtiyoriy) ───────────────────────────
GOOGLE_CLIENT_ID=

# ── TMDB (ixtiyoriy) ──────────────────────────────────
TMDB_API_KEY=
