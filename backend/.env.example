# ── Database ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cineplex

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Email: Resend (birinchi priority) ────────────────
# resend.com dan API key olish: app.resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP — Resend yo'q bo'lsa ishlaydi) ──
# Gmail App Password olish uchun:
#   myaccount.google.com → Security → 2-Step Verification → App passwords
#
# Quyidagi nomlardan istalganini ishlating (barchasi bir xil ishlaydi):
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Yoki SMTP_USER / SMTP_PASS:
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Email "From" nomi (ixtiyoriy):
# MAIL_FROM=CINEPLEX <no-reply@cineplex.app>

# ── Google OAuth (ixtiyoriy) ───────────────────────────
GOOGLE_CLIENT_ID=

# ── CloudFront (video segmentlarini himoyalash) ────────
# Sozlanmasa video himoyasi o'chirilgan holda ishlaydi (S3'ga to'g'ridan-
# to'g'ri kirish davom etadi). To'liq qadamlar uchun: SETUP_CLOUDFRONT.md
# CF_DOMAIN — CloudFront distribution domeni (masalan: cdn.cineplex.uz
#             yoki d111111abcdef8.cloudfront.net)
CF_DOMAIN=
# CF_KEY_PAIR_ID — CloudFront Key Group'da yaratilgan public key ID
CF_KEY_PAIR_ID=
# CF_PRIVATE_KEY — shu key juftligining PRIVATE qismi (PEM, -----BEGIN...
# bilan). Ko'p qatorli bo'lgani uchun .env faylida \n bilan escape qilib
# bitta qatorga yozing — kod buni avtomatik haqiqiy newline'ga aylantiradi.
CF_PRIVATE_KEY=
# CF_COOKIE_DOMAIN — cookie qaysi domen uchun o'rnatilishi (ixtiyoriy).
# API va CDN bitta asosiy domenni bo'lishishi kerak, masalan:
# API: api.cineplex.uz, CDN: cdn.cineplex.uz -> CF_COOKIE_DOMAIN=.cineplex.uz
CF_COOKIE_DOMAIN=
