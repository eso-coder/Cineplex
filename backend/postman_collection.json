{
  "info": {
    "name": "Movie Backend API",
    "description": "Complete REST API for Movie Streaming Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John Doe\", \"email\": \"john@example.com\", \"password\": \"secret123\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@movie.com\", \"password\": \"Admin123!\"}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/update-profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"John Updated\"}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"currentPassword\": \"secret123\", \"newPassword\": \"newSecret456\"}" }
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/movies?page=1&limit=10&sort=newest",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "newest" },
                { "key": "genre", "value": "", "disabled": true },
                { "key": "year", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Featured Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/featured" }
        },
        {
          "name": "Get Trending Movies",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/trending" }
        },
        {
          "name": "Search Movies",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/movies/search?q=inception", "query": [{ "key": "q", "value": "inception" }] }
          }
        },
        {
          "name": "Get Movie by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/movies/MOVIE_ID_HERE" }
        },
        {
          "name": "Increment View",
          "request": { "method": "POST", "url": "{{baseUrl}}/movies/MOVIE_ID_HERE/view" }
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/movies/MOVIE_ID_HERE/favorite",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Toggle Watchlist",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/movies/MOVIE_ID_HERE/watchlist",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get My Favorites",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/user/favorites",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get My Watchlist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/user/watchlist",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Get Movie Comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/comments/movie/MOVIE_ID_HERE"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/comments/movie/MOVIE_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"text\": \"Amazing movie! Highly recommended.\"}" }
          }
        },
        {
          "name": "Edit Comment",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/comments/COMMENT_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"text\": \"Updated comment text.\"}" }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/comments/COMMENT_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Like / Unlike Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/comments/COMMENT_ID_HERE/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Reply to Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/comments/COMMENT_ID_HERE/reply",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"text\": \"Great point!\"}" }
          }
        }
      ]
    },
    {
      "name": "Ratings",
      "item": [
        {
          "name": "Rate Movie",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ratings/movie/MOVIE_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"score\": 9}" }
          }
        },
        {
          "name": "Get My Rating",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ratings/movie/MOVIE_ID_HERE/my-rating",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Delete My Rating",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/ratings/movie/MOVIE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/USER_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"role\": \"admin\", \"isActive\": true}" }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/users/USER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Movie (multipart)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/movies",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "New Movie", "type": "text" },
                { "key": "description", "value": "A great movie description.", "type": "text" },
                { "key": "releaseYear", "value": "2024", "type": "text" },
                { "key": "duration", "value": "120", "type": "text" },
                { "key": "director", "value": "Director Name", "type": "text" },
                { "key": "cast", "value": "Actor 1, Actor 2", "type": "text" },
                { "key": "isFeatured", "value": "false", "type": "text" },
                { "key": "poster", "type": "file", "src": "/path/to/poster.jpg" }
              ]
            }
          }
        },
        {
          "name": "Delete Movie",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/movies/MOVIE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get All Comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/comments",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Genre",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/genres",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Animation\"}" }
          }
        },
        {
          "name": "Update Genre",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/genres/GENRE_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Animated\"}" }
          }
        },
        {
          "name": "Delete Genre",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/genres/GENRE_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "http://localhost:5000/health" }
    }
  ]
}
